{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrcaSpec",
  "description": "Validated spec as structured IR for Orca task decomposition into independently claimable tasks. Supports both application specs and tool/implementation specs.",
  "type": "object",
  "required": ["project", "technicalApproach"],
  
  "schemaVersion": "2.1",

  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "vision", "targetUsers", "problemStatement"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9 ]+$",
          "description": "PascalCase project name"
        },
        "vision": {
          "type": "string",
          "minLength": 20,
          "description": "2-3 sentence description of what this project is and why it exists"
        },
        "targetUsers": {
          "type": "string",
          "minLength": 10
        },
        "problemStatement": {
          "type": "string",
          "minLength": 20
        },
        "successCriteria": {
          "type": "string",
          "minLength": 20
        },
        "specType": {
          "type": "string",
          "enum": ["application", "tool", "hybrid", "unknown"],
          "default": "unknown",
          "description": "Type of spec: application (features & ACs), tool (prompts & protocols), hybrid (both)"
        }
      }
    },

    "coreFeatures": {
      "type": "object",
      "description": "Feature decomposition. Optional for tool specs — if systemPrompts or conversationProtocol exist, this becomes optional.",
      "required": ["mustHave"],
      "properties": {
        "mustHave": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^FEAT-[0-9]+$"
              },
              "description": {
                "type": "string",
                "minLength": 10
              },
              "edgeCases": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "acceptanceCriteria": {
                "type": "object",
                "description": "Per-feature acceptance criteria — used by Orca decompose to create claimable tasks",
                "properties": {
                  "happyPath": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": {
                          "type": "string",
                          "pattern": "^AC-[0-9]+$",
                          "description": "Unique ID for this acceptance criterion, e.g. AC-001"
                        },
                        "criterion": {
                          "type": "string",
                          "description": "Acceptance criterion. Format: Given...When...Then... (application) or free-form (tool)"
                        }
                      }
                    }
                  },
                  "errorHandling": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": {
                          "type": "string",
                          "pattern": "^AC-[0-9]+$"
                        },
                        "criterion": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "shouldHave": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^FEAT-[0-9]+$" },
              "description": { "type": "string", "minLength": 10 },
              "edgeCases": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "acceptanceCriteria": {
                "type": "object",
                "properties": {
                  "happyPath": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
                        "criterion": { "type": "string" }
                      }
                    }
                  },
                  "errorHandling": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
                        "criterion": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "niceToHave": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^FEAT-[0-9]+$" },
              "description": { "type": "string", "minLength": 10 },
              "edgeCases": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "acceptanceCriteria": {
                "type": "object",
                "properties": {
                  "happyPath": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
                        "criterion": { "type": "string" }
                      }
                    }
                  },
                  "errorHandling": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["criterion"],
                      "properties": {
                        "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
                        "criterion": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "technicalApproach": {
      "type": "object",
      "required": ["language", "architecture"],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python", "typescript", "javascript", "go", "rust", "java", "csharp", "cpp", "ruby", "php", "swift", "kotlin", "scala", "bash", "unknown"],
          "description": "Primary language. Use 'unknown' if flexible."
        },
        "architecture": {
          "type": "string",
          "enum": [
            "monolith", "microservices", "serverless", "library", "cli", "daemon", "web", 
            "mobile", "desktop", "embedded", "unknown", "tool", "agentic", "pipeline", 
            "single-process", "multi-process", "orchestration"
          ],
          "description": "Architecture style"
        },
        "framework": {
          "type": "string",
          "default": "none"
        },
        "apiStyle": {
          "type": "string",
          "enum": ["rest", "graphql", "grpc", "websocket", "cli-only", "none", "unknown"],
          "default": "none"
        },
        "database": {
          "type": "string",
          "default": "none"
        },
        "deployment": {
          "type": "string",
          "enum": ["local", "docker", "kubernetes", "cloud-functions", "vm", "serverless", "static", "unknown"],
          "default": "unknown"
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },

    "systemPrompts": {
      "type": "object",
      "description": "System prompt templates for multi-agent, tool, or LLM-driven systems. Each property is a named prompt.",
      "additionalProperties": {
        "type": "string"
      },
      "examples": [
        "{\"interrogator\": \"You are an interrogator...\", \"respondee\": \"You are a subject matter expert...\"}"
      ]
    },

    "conversationProtocol": {
      "type": "object",
      "description": "Protocol for multi-turn conversations or interactions between agents.",
      "properties": {
        "fileFormat": {
          "type": "string",
          "description": "Format of conversation logs (e.g., 'jsonl', 'markdown', 'csv')"
        },
        "delimiter": {
          "type": "string",
          "description": "Delimiter used to separate output sections (e.g., '---RESPONDEE_REVIEW_ONLY---')"
        },
        "turnTypes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Types of turns in the conversation (e.g., 'question', 'answer', 'synthesis')"
        },
        "outputSections": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Expected sections in each output (e.g., '[SYNTHESIZED SPEC DRAFT]', '[NEXT QUESTION]')"
        },
        "stateManagement": {
          "type": "string",
          "description": "How conversation state is managed (e.g., 'file-backed', 'memory-only', 'database')"
        },
        "sessionFormat": {
          "type": "string",
          "description": "Format description for session directories and files"
        }
      }
    },

    "fileStructure": {
      "type": "array",
      "description": "Project file and directory structure. Captures layout that would otherwise be lost.",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File or directory path (e.g., 'orchestrator.py', 'templates/interrogator.txt')"
          },
          "purpose": {
            "type": "string",
            "description": "Purpose or function of this file"
          },
          "type": {
            "type": "string",
            "enum": ["file", "directory", "template", "config", "data"],
            "description": "Type of entry"
          }
        }
      }
    },

    "testingStrategy": {
      "type": "object",
      "properties": {
        "unitTests": {
          "type": "object",
          "properties": {
            "covered": { "type": "boolean" },
            "framework": { "type": "string", "default": "unknown" },
            "coverageTarget": { "type": "number", "minimum": 0, "maximum": 100, "default": 80 }
          }
        },
        "integrationTests": {
          "type": "object",
          "properties": {
            "covered": { "type": "boolean" },
            "approach": {
              "type": "string",
              "enum": ["real-instances", "mocks", "test-containers", "none"],
              "default": "none"
            }
          }
        },
        "e2eTests": {
          "type": "object",
          "properties": {
            "covered": { "type": "boolean" },
            "tool": { "type": "string" },
            "keyJourneys": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "antiCheating": {
          "type": "array",
          "items": { "type": "string" },
          "description": "How to verify tests aren't being cheated"
        }
      }
    },

    "acceptanceCriteria": {
      "type": "object",
      "description": "Project-level acceptance criteria — holistic validation. Format varies by specType (Given/When/Then for application, free-form for tool).",
      "properties": {
        "happyPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errorHandling": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "performance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "security": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "outOfScope": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },

    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "created": { "type": "string", "format": "date" },
        "author": { "type": "string" },
        "schemaVersion": { "type": "string", "description": "Schema version used to validate this IR" }
      }
    }
  }
}