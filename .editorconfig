# =============================================================================
# Editor Configuration
# =============================================================================
# Cross-editor settings for consistent code style

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{py,toml,json,yaml,yml,md,rst}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
